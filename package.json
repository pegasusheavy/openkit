{
  "name": "openkit-styles",
  "version": "1.0.0",
  "private": true,
  "description": "Tailwind CSS styles for OpenKit demos",
  "scripts": {
    "build": "tailwindcss -i ./styles/input.css -o ./examples/styles/tailwind.css --minify",
    "watch": "tailwindcss -i ./styles/input.css -o ./examples/styles/tailwind.css --watch"
  },
  "devDependencies": {
    "tailwindcss": "^4.0.0",
    "@tailwindcss/cli": "^4.0.0"
  }
}
